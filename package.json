{
  "name": "build-discord-app",
  "version": "1.0.1",
  "description": "A CLI tool to scaffold your own Discord bot project quickly",
  "bin": {
    "build-discord-app": "index.js"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "lint": "eslint .",
    "prepublishOnly": "npm run lint && npm audit --audit-level=high"
  },
  "files": [
    "index.js",
    "utils/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "discordjs",
    "discord-app",
    "build-discord-app",
    "cli",
    "scaffolding",
    "slash-commands",
    "discord-bot",
    "djs",
    "discord-app-template",
    "app-creation",
    "discordjs-app",
    "generator",
    "boilerplate"
  ],
  "author": "Dipanshu Sahu",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "degit": "^2.8.4",
    "fs-extra": "^11.3.0",
    "picocolors": "^1.1.1"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dipanshu447/create-discord-app.git"
  },
  "bugs": {
    "url": "https://github.com/dipanshu447/create-discord-app/issues"
  },
  "homepage": "https://github.com/dipanshu447/create-discord-app#readme",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "eslint": "^9.30.1",
    "globals": "^16.3.0"
  }
}
